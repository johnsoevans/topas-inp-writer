		space_group P-31c 
		site Zr1    x 0             y 0             z 0             occ Zr   1          beq = boverall;:1.86126`
		site Zr2    x =1/3;         y =2/3;         z 0.98132       occ Zr   1          beq = boverall;:1.86126`
		site Mo1    x 0.32871       y 0.33891       z 0.149         occ Mo   1          beq = boverall;:1.86126`
		site O1     x 0.1731        y 0.1664        z 0.1008        occ O    1          beq = boverall;:1.86126`
		site O2     x 0.3323        y 0.4959        z 0.0814        occ O    1          beq = boverall;:1.86126`
