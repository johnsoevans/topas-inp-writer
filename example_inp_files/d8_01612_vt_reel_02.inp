		site Mo2    x 0.5           y 0.43252       z 0.8935        occ Mo   1          beq = boverall;:1.86126`
		site O21    x 0.5           y 0.24468       z 0.00257       occ O    1          beq = boverall;:1.86126`
		site O22    x 0.5           y 0.40496       z 0.69087       occ O    1          beq = boverall;:1.86126`
		site O23    x 0.75167       y 0.55746       z 0.9406        occ O    1          beq = boverall;:1.86126`

 		scale scale2  1.00007622e-14` min 1e-14 max 1.e+14
		MVW(mass2  822.198, vol2  384.337`,perc2  0.000`)
		prm scaleZMV2 = scale2 * mass2 * vol2 ;:3.16025375e-09`
		r_bragg  0.658601463
 
		LVol_FWHM_CS_G_L(1, 59.8044809`, 0.89, 56.8118902`, csgc2, 64.0730689` min 30 max 9999, !cslc2, 9999)
		'hkl-dependent strain broadening from Ch4 P124
		prm !zeta  1 min 0 max 1
		prm slc2_average  10000` min 0 max 10000
		spherical_harmonics_hkl ahkl
		'spharm fixed coefficients from range 22
		sh_order  4 load sh_Cij_prm { y00   !ahkl_c00  1.00000 y20   !ahkl_c20  0.34006 y22p  !ahkl_c22p -1.20685 y40   !ahkl_c40  1.75359 y42p  !ahkl_c42p  0.96829 y44p  !ahkl_c44p  0.47733 } 
		prm !sc = 10^-3;
		prm ee_e_scsc = slc2_average ahkl; 
		prm ee_2Th = sc^2 (180/Pi)^2 (-2 Tan(Th))^2 ee_e_scsc;
		gauss_fwhm = (1-zeta) Max(ee_2Th,0)^.5;
		lor_fwhm = zeta Max(ee_2Th,0)^.5;	
	
