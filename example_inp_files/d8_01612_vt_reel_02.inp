	for strs {
		'Instrumental resolution function from d8_00497
		TCHZ_Peak_Type(!pku, 0.00659249534_0.00441957787,!pkv, -0.00957469221_0.00471305525,!pkw,  0.00297466875_0.00120982108,!pkz, 0.0000,!pkx, 0.0465714453_0.00534879623, !pky, 0.0635882971_0.00235706876)
		'Write out phase contribution to .xyd file
