'}}}
  
'{{{ 4. Output lines here 
'Note that reel needs R_wp, Temperature (K) and Wavelength (A) entries to read file
'Column names for these entries in to_Reel.py must match

#define write_out_resultsfile 'Traditional results in wide format for plotting, also read by to_Reel_v1.py

#if (Run_Number == 0)   
	'no append on first output so old file gets deleted  
	'update the headings with right-click/toopas-editor/create column headings
	out resultsFile  ' results file for plotting. Out_String() is file column headers  
	Out_String("Run_Number Temperature lam esd_lam filename_reel filename r_wp gof perc1 esd_perc1 perc2 esd_perc2 perc3 esd_perc3 perc4 esd_perc4 scaleZMV1 esd_scaleZMV1 scaleZMV2 esd_scaleZMV2 scaleZMV3 esd_scaleZMV3 scaleZMV4 esd_scaleZMV4 sum_scaleZMV esd_sum_scaleZMV boverall esd_boverall axial esd_axial height esd_height lpa1 esd_lpa1 lpc1 esd_lpc1 scale1 esd_scale1 csgc1 esd_csgc1 slc1 esd_slc1 lpa2 esd_lpa2 lpb2 esd_lpb2 lpc2 esd_lpc2 scale2 esd_scale2 csgc2 esd_csgc2 slc2_average esd_slc2_average lpa3 esd_lpa3 scale3 esd_scale3 csgc3 esd_csgc3 slc3 esd_slc3 lpa4 esd_lpa4 lpc4 esd_lpc4 scale4 esd_scale4 csgc4 esd_csgc4 slc4 esd_slc4 phase_name \n")
#endif  

#ifdef write_out_resultsfile
		prm sum_scaleZMV = scaleZMV1 + scaleZMV2 + scaleZMV3 + scaleZMV4;:28.5903184`
		out resultsFile append  'append so file retains header
		Out(Run_Number, " %5.0f ") 
		Out(Temperature(Run_Number), "%11.5f ") 
		Out(Get(lam), " %11.9f", " %11.9f ")
		Out_String(filename_reel) 
		Out_String(" ") 
		Out_String(filename) 
		Out(Get(r_wp), " %11.5f") 
		Out(Get(gof), " %11.5f") 
		Out(perc1,        " %18.9f", " %18.9f")  
		Out(perc2,        " %18.9f", " %18.9f")  
		Out(perc3,        " %18.9f", " %18.9f")  
		Out(perc4,        " %18.9f", " %18.9f")  
		Out(scaleZMV1,    " %18.9f", " %18.9f")  
		Out(scaleZMV2,    " %18.9f", " %18.9f")  
		Out(scaleZMV3,    " %18.9f", " %18.9f")  
		Out(scaleZMV4,    " %18.9f", " %18.9f")  
		Out(sum_scaleZMV, " %18.9f", " %18.9f")  
		Out(boverall,     " %18.9f", " %18.9f") 
		Out(axial, " %18.9f", " %18.9f")
		Out(height, " %18.9f", " %18.9f")
		Out(lpa1, " %18.9f", " %18.9f")
		Out(lpc1, " %18.9f", " %18.9f")
		Out(scale1, " %18.9f", " %18.9f")
		Out(csgc1, " %18.9f", " %18.9f")
		Out(slc1, " %18.9f", " %18.9f")
		Out(lpa2, " %18.9f", " %18.9f")
		Out(lpb2, " %18.9f", " %18.9f")
		Out(lpc2, " %18.9f", " %18.9f")
		Out(scale2, " %18.9f", " %18.9f")
		Out(csgc2, " %18.9f", " %18.9f")
		Out(slc2_average, " %18.9f", " %18.9f")
