'{{{ autoclean the .xyd files on last run
'This assumes you have to_Reel_v1.py in the same directory as the INP file
#if (Run_Number == #out pattern_count - 1)
	system_after_save_OUT  { python to_Reel_v1.py results }
#endif
'}}}

'macro to append calculated pattern for individual phases to .xyd file for Reel
macro Writephase 
	{
		out xydFileName append  
		Out(Get(phase_name), "%s\n")
		phase_out_X xydFileName append load out_record out_fmt out_eqn {
			" %11.5f" = X; " %11.5f\n" = Get(phase_ycalc); }
		out xydFileName append  
		Out_String("END\n")
	}

'macro to write Rietveld fit for Reel
macro Write_Rietveld_xyd
	{
		out xydFileName 'write the rietveld fit to .xyd file
		Out_String("tth Y_obs Y_calc Y_res Background\n")
		xdd_out xydFileName append load out_record out_fmt out_eqn { " %11.5f  " = X; " %11.5f  " = Yobs; " %11.5f  " = Ycalc; " %11.5f" = Yobs-Ycalc; "%11.5f\n" = Get(bkg);} 
		out xydFileName append
		Out_String("END OF PHASE\n")
	}
