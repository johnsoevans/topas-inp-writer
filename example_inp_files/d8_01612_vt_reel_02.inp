'{{{ 3. Information for each refinement
xdd filename  
	range Range_Num(Run_Number) 'sets the range to analyse from the #list above
	start_X 14  '10
	finish_X 70  '70
	x_calculation_step = Yobs_dx_at(Xo);
	bkg @  159.381379` -151.113674`  79.3040969` -19.764994` -10.609985`  12.4384167` -2.26099996` -8.54426139`  11.9950539` -11.7682044`  8.89803688` -2.89111757`
	Simple_Axial_Model(axial, 3.23420516`)
	'Bragg Brentano Cu Ka1 Ge(111) mono PSD
	LP_Factor(!th2_monochromator, 27.26)
	CuKa1(0.0001)
	Specimen_Displacement(height, 0.0177190455`)  
	prm boverall  1.8612633` min 0 max 10 'use a single overall temperature factor for each phase

	Write_Rietveld_xyd

	str  
		phase_name ZrMo2O7(OH)2.2H2O
