		LVol_FWHM_CS_G_L(1, 70.1692222`, 0.89, 66.6905904`, csgc1, 75.2624109` min 30 max 9999, !cslc1, 9999)
		e0_from_Strain( 0.000217918606`, !sgc1, 0.001, slc1, 0.1` min 1e-9 max 0.1)

	str 
		phase_name LT-ZrMo2O8
 		a  lpa2  5.800158` min =5.80; max =5.90; 
 		b  lpb2  7.330000` min =7.33; max =7.43; 
 		c  lpc2  9.040000` min =9.04; max =9.15; 
