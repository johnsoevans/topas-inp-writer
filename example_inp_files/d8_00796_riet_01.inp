		'restrain distances and angles on one benzene rinng and flatten ring to keep planar	 
		'in this case all the sites are in the asymmetric unit so the format is simple
		'to restrain to symmetry generated atoms you need the full site label
		'for C11 this would be C11 0 0 0 0 in this case,
		'where the first number refers to the symmetry operator and the last three to unit cell offsets
		'the labels can be found from a distance and angles calculation and the format is at the end of the file.
		Distance_Restrain(C11 C12, 1.400, 1.3972402`, 0, 1) 
		Distance_Restrain(C12 C13, 1.400, 1.39877626`, 0, 1) 
		Distance_Restrain(C13 C14, 1.400, 1.66214106`, 0, 1) 
		Distance_Restrain(C14 C15, 1.400, 1.3320902`, 0, 1) 
		Distance_Restrain(C15 C16, 1.400, 1.32651322`, 0, 1) 
		Distance_Restrain(C16 C11, 1.400, 1.60480338`, 0, 1) 
			
		Angle_Restrain(C11 C12 C13,120, 112.78568`,0, .001) 
		Angle_Restrain(C12 C13 C14,120, 118.15927`,0, .001) 
		Angle_Restrain(C13 C14 C15,120, 119.651666`,0, .001) 
		Angle_Restrain(C14 C15 C16,120, 126.293943`,0, .001) 
		Angle_Restrain(C15 C16 C11,120, 112.284585`,0, .001) 
		Angle_Restrain(C16 C11 C12,120, 129.02292`,0, .001) 

		Flatten(C11 C12 C13 C14 C15 C16, 0.0255633122`, 0.0052320798,10) 
 
		'restrain  distances and angles on second benzene ring and flatten ring to keep planar		 
		Distance_Restrain(C21 C22, 1.400, 1.34283365`, 0, 1) 
		Distance_Restrain(C22 C23, 1.400, 1.49201844`, 0, 1) 
		Distance_Restrain(C23 C24, 1.400, 1.33691272`, 0, 1) 
		Distance_Restrain(C24 C25, 1.400, 1.50483526`, 0, 1) 
		Distance_Restrain(C25 C26, 1.400, 1.55606755`, 0, 1) 
		Distance_Restrain(C26 C21, 1.400, 1.54776494`, 0, 1) 
			
		Angle_Restrain(C21 C22 C23,120, 123.098641`,0, .001) 
		Angle_Restrain(C22 C23 C24,120, 119.099787`,0, .001) 
		Angle_Restrain(C23 C24 C25,120, 121.728423`,0, .001) 
