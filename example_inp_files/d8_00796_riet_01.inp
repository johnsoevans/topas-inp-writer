		Flatten(C21 C22 C23 C24 C25 C26, 0.0367937101`, 0.0193627754,10) 

		'restrain central linking group		 
		Distance_Restrain(C21 C2 , 1.430, 1.77112626`, 0, 1) 
		Distance_Restrain(C11 C1 , 1.430, 1.21837502`, 0, 1) 
		Distance_Restrain(C2  C1 , 1.200, 1.50350679`, 0, 1) 

		'restrain distances on nme2 group and keep it planar
		Distance_Restrain(C14 N1 , 1.380, 1.46313523`, 0, 1) 
		Distance_Restrain(N1  C3 , 1.450, 1.49635818`, 0, 1) 
		Distance_Restrain(N1  C4 , 1.450, 1.61425024`, 0, 1) 
			
		Flatten(N1 C3 C4 C14, 0.002609014`, 0.00189953319,10) 

