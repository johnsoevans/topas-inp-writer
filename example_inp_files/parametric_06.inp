'here's the magic: set up a counting variable for xdds and create the xdd set for each file in #list
'i set at this top level (before xdds) - necessary for existing_prm to work
prm i = 0;	
Create_XDDs(#list_n T_val) 
'New_XDDs(#list_n T_val) 'old syntax command
'}}} 

'{{{ 3. Overall parameters describing parametric fitting and macros feeding into each of the 3 phases
#ifdef param_cell 
'equations describing cell parameter vs T and angle vs T
	fn cell_fT(a0,grad,theta,te) = a0 + (grad/(Exp(theta/te)-1));
	fn angle_fT(a0,a1,a2,te) = a0 * (1 + a1 * 1e-6 * te + a2 * 1e-9 * te^2 );

'cell edge description refineable parameters for Pc, P-1 and P21/n phases
   prm zero_ma   7.29874518` prm   grad_ma  0.000500349748` val_on_continue = Val*Rand(0.99,1.01); prm  theta_ma  60.0205569`
   prm zero_mb   7.49912737` prm   grad_mb  0.00888545488` val_on_continue = Val*Rand(0.99,1.01); prm !theta_mb  =theta_ma;:60.0205569`
   prm zero_mc   7.65354657` prm   grad_mc  0.00864660405` val_on_continue = Val*Rand(0.99,1.01); prm !theta_mc  =theta_ma;:60.0205569`
   prm zero_ta   7.30989963` prm   grad_ta -5.41572581e-05` val_on_continue = Val*Rand(0.99,1.01); prm !theta_ta  =theta_ma;:60.0205569`
   prm zero_tb   7.48556928` prm   grad_tb  0.00838039321` val_on_continue = Val*Rand(0.99,1.01); prm !theta_tb  =theta_ma;:60.0205569`
   prm zero_tc   7.64888484` prm   grad_tc  0.0102861025` val_on_continue = Val*Rand(0.99,1.01); prm !theta_tc  =theta_ma;:60.0205569`
   prm zero_pa   5.27256347` prm   grad_pa  0.00247186279` val_on_continue = Val*Rand(0.99,1.01); prm !theta_pa  =theta_ma;:60.0205569`
   prm zero_pb   5.15772684` prm   grad_pb  0.00154598106` val_on_continue = Val*Rand(0.99,1.01); prm !theta_pb  =theta_ma;:60.0205569`
   prm zero_pc   7.65772806` prm   grad_pc  0.00555767741` val_on_continue = Val*Rand(0.99,1.01); prm !theta_pc  =theta_ma;:60.0205569`
'cell angle descriptionrefineable parameters for Pc, P-1 and P21/n phases                      
   prm  beta_m0  91.1982055` prm   beta_m1 -12.7701711` val_on_continue = 0;  prm    beta_m2  1.39043877` val_on_continue = 0; 
   prm  alph_t0  89.1945298` prm   alph_t1 -52.6577284` val_on_continue = 0;  prm    alph_t2  171.585628` val_on_continue = 0; 
   prm  beta_t0  89.5889293` prm   beta_t1  163.798877` val_on_continue = 0;   prm   beta_t2 -470.696672` val_on_continue = 0; 
   prm  gamm_t0  89.6598446` prm   gamm_t1  109.455795` val_on_continue = 0;   prm   gamm_t2 -233.986536` val_on_continue = 0; 
   prm  beta_p0  91.8703395` prm   beta_p1 -31.7309835` val_on_continue = 0;  prm    beta_p2  111.824913` val_on_continue = 0; 
#endif 
'commands that go into each of the phases
macro Phase_Common(n, scv)
   { 
      extra_X_right 2
      local sc scv min 1e-10
      scale = sc;
      out "results.txt" append
      output_lines
    }  
'}}}  	 

'{{{ 4. This for xdds section defines all of the Rietveld fits for all of the created xdds
'local parameters are used which get saved to the .sv stored values file then read in on subsequent refinements
'topas automatically sorts out local and global parameters according to names
for xdds {
	xdd_file = #Files(i);  'set up filename
	local !te = #T_val(i); 'set up temperature
	range = #Range_val(i); 'set up range number in raw data file
	existing_prm i += 1;
	x_calculation_step = Yobs_dx_at(Xo); convolution_step 2 
	start_X 20  
    finish_X 80.0  
    LP_Factor(!th2_monochromator, 0) 
	CuKa2(0.0001) 
	Zero_Error(!zero, 0.0) 'refine height for each phase so zero point not needed 
    local height -0.0347520605` min = -0.5; max = 0.5; del 0.001  th2_offset = -2 57.2957795130823 (height) Cos(Th) / Rs; 
	Simple_Axial_Model(!axial, 5.74444) 'from a standard on instrument
    local  individual_b -0.972990527` min -1 max 10 'single bvalue for all phases 
	scale_pks = (Exp(-2*individual_b/(2 D_spacing)^2)); 'bvalue for all phases in each dataset 
    local bkg0  61.3670083`
    local bkg1 -57.91513`
    local bkg2  33.8441769`
    local bkg3 -23.5859545`
    local bkg4  13.8796824`
    local bkg5 -4.42188244`
    bkg = bkg0; = bkg1; = bkg2; = bkg3; = bkg4; = bkg5;
   
	'{{{ write out xdd specific results here; phase-specific info done for each str via the Phase_Common macro    
	#ifdef write_out 
		out "results.txt" append 
		Out(te, "\n %11.5f") 
		Out(Get (r_wp), " %11.5f") 
	#endif    
	'write out rietveld fits and/or obs, calc, diff files here if requested   
	#ifdef riet_out 
      xdd_out = Concat("riet_plots\riet_", #Range_val(i-1), ".xyd"); load out_record out_fmt out_eqn { " %11.5f " = X; " %11.5f" = Yobs; " %11.5f" = Yobs; " %11.5f\n" = Yobs-Ycalc;} 
      xdd_out = Concat("obs_plots\obs_", #Range_val(i-1), ".xy"); load out_record out_fmt out_eqn { " %11.5f " = X; " %11.5f\n" = Yobs; } 
      xdd_out = Concat("calc_plots\calc_", #Range_val(i-1), ".xy"); load out_record out_fmt out_eqn { " %11.5f " = X; " %11.5f\n" = Ycalc; } 
      xdd_out = Concat("diff_plots\diff_", #Range_val(i-1), ".xy"); load out_record out_fmt out_eqn { " %11.5f " = X; " %11.5f\n" = Yobs-Ycalc; } 
    #endif 

   '}}} 
    
   '{{{ P21/n structure information    
	str 
		phase_name p21n 
		#ifdef param_cell 
			a = cell_fT(zero_ma,grad_ma,theta_ma,te);:7.300100`
			b = cell_fT(zero_mb,grad_mb,theta_mb,te);:7.523780`
			c = cell_fT(zero_mc,grad_mc,theta_mc,te);:7.692586`
			al 90.       
			be = angle_fT(beta_m0,beta_m1,beta_m2,te);:90.86023`
			ga 90 
		#else 
			a  @  7.303501 mlpaminmax 
			b  @  7.535426 mlpbminmax 
			c  @  7.687912 mlpcminmax 
			al   90.       
			be @  91.01850 mbetminmax 
			ga   90. 
		#endif           
		space_group "P121/n1" 
		Phase_Common(1, 7.60389134e-07`)
		weight_percent  76.937`
		Phase_Density_g_on_cm3( 7.28323831`) 
		r_bragg  5.62048616
		'ideal val2 coordinates from Woodward P21/n 
		site W1  A1( xW1, 0.25283` , 0.25130) A2( yW1, 0.03197` , 0.02770) A3( zW1, 0.27936` , 0.28650) occ     W 1.0000 beq !bval 0 
		site W2  A1( xW2, 0.24587` , 0.24810) A2( yW2, 0.02903` , 0.03420) A3( zW2, 0.78506` , 0.78150) occ     W 1.0000 beq !bval 0 
		site O3  A1(!xO3, 0.00143 , 0.00143) A2(!yO3, 0.03550 , 0.03550) A3(!zO3, 0.21526 , 0.21526) occ     O 1.0000 beq !bval 0 
		site O4  A1(!xO4, 0.99858 , 0.99858) A2(!yO4, 0.46301 , 0.46301) A3(!zO4, 0.21782 , 0.21782) occ     O 1.0000 beq !bval 0 
		site O5  A1(!xO5, 0.28165 , 0.28165) A2(!yO5, 0.26251 , 0.26251) A3(!zO5, 0.28384 , 0.28384) occ     O 1.0000 beq !bval 0 
		site O6  A1(!xO6, 0.20905 , 0.20905) A2(!yO6, 0.25985 , 0.25985) A3(!zO6, 0.73375 , 0.73375) occ     O 1.0000 beq !bval 0 
		site O7  A1(!xO7, 0.27950 , 0.27950) A2(!yO7, 0.04128 , 0.04128) A3(!zO7, 0.00461 , 0.00461) occ     O 1.0000 beq !bval 0 
		site O8  A1(!xO8, 0.28259 , 0.28259) A2(!yO8, 0.48854 , 0.48854) A3(!zO8, 0.99449 , 0.99449) occ     O 1.0000 beq !bval 0	 
		Strain_G(strainG_p21n, 0.182835275` vcstrain) 
		Strain_L(strainL_p21n, 0.157337816` vcstrain) 
	'}}}} 
	'{{{ Pb1 structure information    
	str 
		phase_name pb1 
		#ifdef param_cell 
			a = cell_fT(zero_ta,grad_ta,theta_ta,te);:7.309655`
			b = cell_fT(zero_tb,grad_tb,theta_tb,te);:7.523406`
			c = cell_fT(zero_tc,grad_tc,theta_tc,te);:7.695326`
			al = angle_fT(alph_t0,alph_t1,alph_t2,te);:88.83427`
			be = angle_fT(beta_t0,beta_t1,beta_t2,te);:90.64701`
			ga = angle_fT(gamm_t0,gamm_t1,gamm_t2,te);:90.73722`
		#else 
			a  @  7.339178 tlpaminmax  
			b  @  7.507749 tlpbminmax  
			c  @  7.680995 tlpcminmax  
			al @  88.90828 tlpalminmax 
			be @  90.60022 tlpbeminmax 
			ga @  90.95586 tlpgaminmax 
		#endif 
		space_group "P-1" 
		Phase_Common(2, 4.87607063e-06`)
		weight_percent  17.403`
		Phase_Density_g_on_cm3( 7.31565953`) 
		r_bragg  3.17924998
		'ideal val2 coordinates from Woodward 80053 
		site W21  A1( xW21, 0.26204` , 0.25660) A2( yW21, 0.02519` , 0.02590) A3( zW21, 0.28980` , 0.28500) occ     W 1.0000 beq !bval 0 
		site W22  A1( xW22, 0.24417` , 0.25020) A2( yW22, 0.51680` , 0.52800) A3( zW22, 0.20998` , 0.21580) occ     W 1.0000 beq !bval 0 
		site W23  A1( xW23, 0.24173` , 0.24380) A2( yW23, 0.02875` , 0.03130) A3( zW23, 0.78053` , 0.78170) occ     W 1.0000 beq !bval 0 
		site W24  A1( xW24, 0.25204` , 0.24990) A2( yW24, 0.54015` , 0.53380) A3( zW24, 0.72442` , 0.71900) occ     W 1.0000 beq !bval 0 
		site O25  A1(!xO25, 0.00120 , 0.00120) A2(!yO25, 0.03400 , 0.03400) A3(!zO25, 0.21090 , 0.21090) occ     O 1.0000 beq !bval 0 
		site O26  A1(!xO26, 0.50100 , 0.50100) A2(!yO26, 0.53790 , 0.53790) A3(!zO26, 0.21700 , 0.21700) occ     O 1.0000 beq !bval 0 
		site O27  A1(!xO27, 0.00070 , 0.00070) A2(!yO27, 0.46400 , 0.46400) A3(!zO27, 0.28570 , 0.28570) occ     O 1.0000 beq !bval 0 
		site O28  A1(!xO28, 0.49940 , 0.49940) A2(!yO28, 0.96480 , 0.96480) A3(!zO28, 0.28850 , 0.28850) occ     O 1.0000 beq !bval 0 
		site O29  A1(!xO29, 0.28750 , 0.28750) A2(!yO29, 0.26000 , 0.26000) A3(!zO29, 0.28430 , 0.28430) occ     O 1.0000 beq !bval 0 
		site O10  A1(!xO10, 0.21150 , 0.21150) A2(!yO10, 0.76190 , 0.76190) A3(!zO10, 0.21570 , 0.21570) occ     O 1.0000 beq !bval 0 
