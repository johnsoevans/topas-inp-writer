	'{{{ Pc structure information    
	str 
		phase_name pc 
		#ifdef param_cell 
			a = cell_fT(zero_pa,grad_pa,theta_pa,te);:5.279790`
			b = cell_fT(zero_pb,grad_pb,theta_pb,te);:5.162246`
